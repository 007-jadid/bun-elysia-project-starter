# Test environment (NODE_ENV=test, auto-set by `bun test`). Committed,
# non-secret values. Bun does NOT load .env.local when NODE_ENV=test, so the
# required vars must be present here for modules that import config/env.
# Tests never hit these endpoints — connection-dependent suites skip when the
# backing service is unreachable.

NODE_ENV=test
DEPLOY_ENV=local
PORT=3001
HOST=0.0.0.0
SERVICE_NAME=app-service
SERVICE_VERSION=1.0.0

# Write Database
WRITE_DB_HOST=localhost
WRITE_DB_PORT=5433
WRITE_DB_NAME=app_db_test
WRITE_DB_USER=app
WRITE_DB_PASS=app_local_pass
WRITE_DB_IDLE_TIMEOUT=30
WRITE_DB_ENABLE_SSL_MODE=false
WRITE_DB_POOL_MAX=5

# Read Database
READ_DB_HOST=localhost
READ_DB_PORT=5433
READ_DB_NAME=app_db_test
READ_DB_USER=app
READ_DB_PASS=app_local_pass
READ_DB_IDLE_TIMEOUT=30
READ_DB_ENABLE_SSL_MODE=false
READ_DB_POOL_MAX=5

# Redis
WRITE_REDIS_URL=redis://localhost:6379
READ_REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Auth (test-only secret, >= 32 chars)
JWT_SECRET=test_only_secret_not_for_real_use_0123456789
JWT_ISSUER=https://api.example.com
JWT_AUDIENCE=app

# Security
REQUEST_BODY_MAX_SIZE=1048576
REQUEST_BODY_UPLOAD_MAX_SIZE=6291456

# OpenTelemetry
OTEL_ENABLED=false

# Logging — keep test output quiet
LOG_LEVEL=error

# OpenAPI Docs
ENABLE_OPENAPI=false

# S3 — dummy values; tests never hit the network
S3_BUCKET=test-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=test-access-key
S3_SECRET_ACCESS_KEY=test-secret-key
S3_SERVICE_FOLDER=uploads
