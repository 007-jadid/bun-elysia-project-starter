{
  "name": "bun-elysia-clean-starter",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run verify && NODE_ENV=development bun run --watch src/index.ts",
    "start": "NODE_ENV=production bun run src/index.ts",
    "start:dev": "NODE_ENV=development bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "verify": "bun run typecheck && bun run check",
    "deps:up": "docker compose -f docker-compose.deps.yml up -d",
    "deps:down": "docker compose -f docker-compose.deps.yml down",
    "deps:logs": "docker compose -f docker-compose.deps.yml logs -f",
    "deps:reset": "docker compose -f docker-compose.deps.yml down -v && docker compose -f docker-compose.deps.yml up -d",
    "db:generate": "bunx --bun drizzle-kit generate --config=./src/infrastructure/db/drizzle.config.ts",
    "db:migrate": "bunx --bun drizzle-kit migrate --config=./src/infrastructure/db/drizzle.config.ts",
    "db:push": "bunx --bun drizzle-kit push --config=./src/infrastructure/db/drizzle.config.ts",
    "db:studio": "bunx --bun drizzle-kit studio --config=./src/infrastructure/db/drizzle.config.ts"
  },
  "dependencies": {
    "@bogeychan/elysia-logger": "^0.1.10",
    "@elysiajs/bearer": "^1.4.4",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "@elysiajs/opentelemetry": "^1.4.11",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "amqplib": "^2.0.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/amqplib": "^0.10.8",
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3"
  }
}
