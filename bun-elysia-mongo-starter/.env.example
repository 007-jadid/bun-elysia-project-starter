# Reference for every environment variable this service reads (see
# src/config/env.ts for validation rules and defaults). Copy what you need into
# .env.local (gitignored) for personal overrides. Committed templates already
# exist for each NODE_ENV: .env.local / .env.development / .env.production.

# App
NODE_ENV=development          # development | test | production
DEPLOY_ENV=local              # local | dev | stage | uat | production
PORT=4445
HOST=0.0.0.0
SERVICE_NAME=app-service
SERVICE_VERSION=1.0.0

# MongoDB (required)
MONGO_URI=mongodb://localhost:27017/app_db

# Redis (required, read/write split)
WRITE_REDIS_URL=redis://localhost:6379
READ_REDIS_URL=redis://localhost:6379

# RabbitMQ (required)
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# gRPC server
GRPC_PORT=50051
GRPC_SHARED_SECRET=           # optional; when set, callers must send x-api-key

# Auth (required; JWT_SECRET must be >= 32 chars)
JWT_SECRET=local_dev_secret_change_me_please_0123456789
JWT_ISSUER=https://api.example.com
JWT_AUDIENCE=app

# S3 (required)
S3_BUCKET=your-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-s3-access-key-id
S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
S3_ENDPOINT=                  # optional; for non-AWS S3-compatible services
S3_SERVICE_FOLDER=uploads

# Security
REQUEST_BODY_MAX_SIZE=1048576 # 1MB
MAX_UPLOAD_SIZE=52428800      # 50MB

# OpenTelemetry (optional)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf   # http/protobuf | grpc
OTEL_EXPORTER_OTLP_HEADERS=                 # required in prod when OTEL enabled
OTEL_METRICS_ENABLED=true
OTEL_METRICS_EXPORT_INTERVAL_MS=10000

# Loki (optional log shipping)
LOKI_ENABLED=false
LOKI_HOST=
LOKI_BASIC_AUTH=

# Logging
LOG_LEVEL=info                # trace | debug | info | warn | error | fatal

# OpenAPI Docs
ENABLE_OPENAPI=true
OPENAPI_SERVER_URL=http://localhost:4445
